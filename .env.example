# ── 필수 ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=REPLACE_ME
BOT_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── 데이터베이스 ──────────────────────────────────────────
BOT_DB_PATH=./bot.db

# ── Ollama ────────────────────────────────────────────────
OLLAMA_BASE=http://127.0.0.1:11434
DEFAULT_MODEL=
OLLAMA_TIMEOUT_SEC=120
OLLAMA_STARTUP_WAIT_SEC=30
PM2_BIN=pm2

# ── 인증 ──────────────────────────────────────────────────
SESSION_TTL_SEC=86400
LOGIN_MAX_FAILS=5
LOGIN_LOCK_SEC=600

# ── 컨텍스트 (기본값, 사용자가 /settings 에서 조절 가능) ──
CONTEXT_TURNS=6
CONTEXT_TTL_SEC=900

# ── 스트리밍 ──────────────────────────────────────────────
STREAMING_EDIT_INTERVAL=1.5
STREAMING_MIN_DELTA=20

# ── 도구 ──────────────────────────────────────────────────
TOOL_SANDBOX_PATH=/Users/macmini/workspace/sandbox
TOOL_SANDBOX_ENABLED=true          # false로 설정하면 파일 접근 경로 제한 해제 (전체 서버 접근)
CODE_EXECUTION_TIMEOUT=30
TOOL_MAX_ITERATIONS=5
DUCKDUCKGO_MAX_RESULTS=5

# ── 컨텍스트 요약 ─────────────────────────────────────────
SUMMARY_THRESHOLD_TOKENS=100000
MAX_FILE_READ_CHARS=50000

# ── 모델 캐시 ─────────────────────────────────────────────
MODEL_VISION_CACHE_TTL_SEC=3600
